# ---------- Analytics / Ad tracking (optional) ----------
# If omitted, tracking scripts and events are safely skipped.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=123456789012345
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=123456

# ---------- Contact delivery (optional but recommended for production) ----------
# If all three vars are provided, /api/contact sends lead emails via Resend.
# If missing, the API falls back to local contact-submissions.json storage.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTACT_FROM_EMAIL=leads@yourdomain.com
CONTACT_TO_EMAIL=sales@yourdomain.com
